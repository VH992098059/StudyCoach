# ========================================
# StudyCoach 环境变量模板
# ========================================

# --- 数据库 ---
MYSQL_ROOT_PASSWORD=your_mysql_password
MYSQL_DATABASE=studyCoach

# --- Redis ---
REDIS_PASSWORD=your_redis_password

# --- AI 模型 (火山引擎 Ark) ---
ARK_API_KEY=your_ark_api_key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=your_model_id

# --- AI 模型 (SiliconFlow) ---
SILICONFLOW_API_KEY=your_siliconflow_api_key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=your_model_id

# --- Embedding ---
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=your_embedding_model

# --- Rerank ---
RERANK_API_KEY=your_rerank_api_key
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_MODEL=your_rerank_model

# --- 语音 ---
VOICE_API_KEY=your_voice_api_key

# --- 向量引擎 (es / qdrant / milvus) ---
VECTOR_ENGINE=es

# --- Elasticsearch ---
ES_ADDRESS=http://127.0.0.1:9200

# --- Qdrant ---
QDRANT_ADDRESS=127.0.0.1:6334

# --- SeaweedFS ---
SEAWEEDFS_FILER=http://127.0.0.1:8888

# --- JWT ---
JWT_SECRET=your_jwt_secret_key

# --- 监控 ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password

# --- Docker Registry ---
DOCKER_REGISTRY=your-registry.com
DOCKER_NAMESPACE=studycoach
DOCKER_USERNAME=your_username
DOCKER_PASSWORD=your_password
